<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontal divider between the widget header and action buttons -->
<!-- Using a gradient fade from transparent → white → transparent for an elegant centerline effect -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Horizontal center-fade: invisible at edges, brightest in the middle -->
    <gradient
        android:startColor="#00FFFFFF"
        android:centerColor="#20FFFFFF"
        android:endColor="#00FFFFFF"
        android:angle="0"
        android:type="linear" />
    <size android:height="1dp" />
</shape>
