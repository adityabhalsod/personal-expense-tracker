<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_expense_tracker.xml — Modern Quick-Add Home Screen Widget.

    Structure:
      ┌─────────────────────────────────────────────────────────┐
      │  ███ 3dp violet accent strip                            │
      │  [🏦 Expense Tracker]              [Quick Log]          │  ← header
      │  ─ ─ ─ ─ ─ ─ ─ ─ gradient divider ─ ─ ─ ─ ─ ─ ─ ─   │
      │  [ ↑ Add Expense   ] │ [ ↓ Got Payment ]               │  ← buttons
      │  [ Tap to log debit] │ [ Tap to log credit]            │
      └─────────────────────────────────────────────────────────┘

    Only RemoteViews-safe views used: LinearLayout, TextView, ImageView, View.
    PendingIntents are bound in ExpenseWidget.kt via setOnClickPendingIntent().
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@drawable/widget_background">

    <!-- ── Accent strip: 3dp primary-violet gradient at very top of card ── -->
    <!-- Visually anchors the widget to the app's brand color on any wallpaper -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@drawable/widget_accent_strip" />

    <!-- ── Content wrapper: padding applied here, not on root, so strip bleeds edge-to-edge ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- ── Header row: launcher icon + app name + "Quick Log" pill badge ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Small launcher icon (20dp) for brand recognition -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter"
                android:layout_marginEnd="7dp" />

            <!-- App name: medium-weight, full white -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Expense Tracker"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- "Quick Log" pill badge: subtle violet-tinted label at right edge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Log"
                android:textColor="#CCE8E8FF"
                android:textSize="9.5sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/widget_badge"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <!-- ── Center-fade gradient divider between header and buttons ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/widget_divider"
            android:layout_marginBottom="9dp" />

        <!-- ── Action buttons row — fills all remaining vertical space ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- ── ADD EXPENSE button (left) ── -->
            <!--
                PendingIntent target: expense-tracker://quick-add?type=expense
                Bound in ExpenseWidget.kt: views.setOnClickPendingIntent(R.id.btn_add_expense, …)
            -->
            <LinearLayout
                android:id="@+id/btn_add_expense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/btn_widget_expense"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp">

                <!-- Upward arrow: indicates money going out (debit) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑"
                    android:textColor="#EF4444"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

                <!-- Primary button label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Expense"
                    android:textColor="#FFFFFF"
                    android:textSize="11.5sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />

                <!-- Secondary hint text: reinforces tap-to-log intent -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to log debit"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <!-- ── GOT PAYMENT button (right) ── -->
            <!--
                PendingIntent target: expense-tracker://quick-add?type=income
                Bound in ExpenseWidget.kt: views.setOnClickPendingIntent(R.id.btn_payment_received, …)
            -->
            <LinearLayout
                android:id="@+id/btn_payment_received"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/btn_widget_income"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp">

                <!-- Downward arrow: indicates money coming in (credit) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓"
                    android:textColor="#10B981"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

                <!-- Primary button label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Got Payment"
                    android:textColor="#FFFFFF"
                    android:textSize="11.5sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />

                <!-- Secondary hint text: reinforces tap-to-log intent -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to log credit"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

