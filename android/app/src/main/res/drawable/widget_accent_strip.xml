<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_accent_strip.xml
    3dp tall primary-violet to lighter-violet gradient line rendered at the very top
    of the widget card, above all content. Gives the card a branded identity accent
    that stands out on any wallpaper color.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Horizontal sweep from primary violet to its lighter variant -->
    <gradient
        android:startColor="#6C63FF"
        android:centerColor="#8B85FF"
        android:endColor="#6C63FF"
        android:angle="0"
        android:type="linear" />
</shape>
