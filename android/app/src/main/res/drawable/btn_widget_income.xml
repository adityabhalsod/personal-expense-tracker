<?xml version="1.0" encoding="utf-8"?>
<!--
    Income button background: two-layer outlined design.
    Layer 1 — very subtle green tint fill for a positive/success feeling.
    Layer 2 — green stroke border (40% opacity) matching the expense button pattern.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Subtle green fill — complementary contrast to the red expense button -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1510B981" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Stroke ring: green at ~38% opacity for outlined card style -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#6010B981" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</layer-list>
