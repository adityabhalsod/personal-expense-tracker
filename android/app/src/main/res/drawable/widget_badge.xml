<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_badge.xml
    Rounded pill background for the "Quick Log" label in the widget header.
    Uses a very subtle primary-violet tint at low opacity so it reads as a soft badge
    without drawing too much attention away from the action buttons.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 20% opacity primary violet fill — readable but visually quiet -->
    <solid android:color="#336C63FF" />
    <!-- Tightest radius for a tight pill shape around short text -->
    <corners android:radius="6dp" />
</shape>
