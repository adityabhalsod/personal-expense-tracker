<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget card background: two-layer design.
    Layer 1 — deep dark gradient base (matches app dark theme colors).
    Layer 2 — subtle primary-violet stroke border for a modern frosted-glass card feel.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: dark indigo gradient matching the app's dark surface palette -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E1B38"
                android:centerColor="#171530"
                android:endColor="#0F0F24"
                android:angle="150"
                android:type="linear" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Border: 1dp primary-violet ring at low opacity — gives the card-on-wallpaper look -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" /><!-- transparent fill -->
            <stroke android:width="1dp" android:color="#406C63FF" />
            <corners android:radius="22dp" />
        </shape>
    </item>

</layer-list>
