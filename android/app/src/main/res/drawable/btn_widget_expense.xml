<?xml version="1.0" encoding="utf-8"?>
<!--
    Expense button background: two-layer outlined design.
    Layer 1 — very subtle red tint fill for warmth without obscuring the card gradient.
    Layer 2 — red stroke border (40% opacity) for the modern outlined-button look.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Subtle red fill — enough to feel "warm" but not overpowering -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#15EF4444" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Stroke ring: red at ~38% opacity for outlined card style -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#60EF4444" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</layer-list>
